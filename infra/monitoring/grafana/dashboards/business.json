        }
      ]
    },
    {
      "title": "Écart moyen clôture (FCFA)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "avg(business_closing_gap_amount)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyXOF",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 50000 }
            ]
          }
        }
      }
    },
    {
      "title": "Dépenses par catégorie (semaine)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "increase(business_expenses_amount_by_category[7d])",
          "legendFormat": "{{ category }}"
        }
      ]
    },
    {
      "title": "Dépenses par statut",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "business_expenses_by_status",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "title": "Taux d'approbation",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "(increase(business_expenses_approved_total[7d]) / increase(business_expenses_submitted_total[7d])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Consommation budget par catégorie (%)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "(business_budget_consumed / business_budget_allocated) * 100",
          "legendFormat": "{{ category }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    }
