{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Prédictions / heure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(ai_predictions_total[1h]) * 3600",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Latence modèle (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_prediction_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "Total prédictions (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(ai_predictions_total[24h]))"
        }
      ]
    },
    {
      "title": "Taux erreurs IA",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "(sum(rate(ai_prediction_errors_total[1h])) / sum(rate(ai_predictions_total[1h]))) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Latence moyenne",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(ai_prediction_duration_seconds_sum[5m])) / sum(rate(ai_prediction_duration_seconds_count[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Catégorisation confiance avg",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "avg(ai_categorization_confidence) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Model Drift Score",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "ai_model_drift_score",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "title": "Anomalies détectées / jour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "increase(ai_anomalies_detected_total[1d])",
          "legendFormat": "Anomalies"
        },
        {
          "expr": "increase(ai_anomalies_confirmed_total[1d])",
          "legendFormat": "Confirmées"
        }
      ]
    },
    {
      "title": "Prédictions par type de modèle",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(ai_predictions_total[24h])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "title": "Dernier réentraînement",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "(time() - ai_model_last_trained_timestamp) / 3600",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 168 },
              { "color": "red", "value": 336 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["caisseflow", "ai"],
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "query": "label_values(ai_predictions_total, model)",
        "datasource": "Prometheus",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "title": "CaisseFlow — IA",
  "uid": "caisseflow-ai"
}
