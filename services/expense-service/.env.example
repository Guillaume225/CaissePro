# ─── App ───
PORT=3002
NODE_ENV=development

# ─── PostgreSQL ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=caisseflow
POSTGRES_PASSWORD=caisseflow
POSTGRES_DB=caisseflow

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT (shared with auth-service) ───
JWT_PUBLIC_KEY=
JWT_SECRET=dev-secret-change-in-production

# ─── RabbitMQ ───
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── File Upload ───
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_FILES=5

# ─── Throttling ───
THROTTLE_TTL=60
THROTTLE_LIMIT=100
