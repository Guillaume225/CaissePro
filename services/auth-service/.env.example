# ── CaisseFlow Auth Service ──
NODE_ENV=development
PORT=3001

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=caisseflow
POSTGRES_PASSWORD=caisseflow
POSTGRES_DB=caisseflow

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── RSA Keys (generate with: openssl genrsa 2048) ──
# Paste the full PEM including -----BEGIN/END RSA PRIVATE KEY-----
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA0Z3VS5JJcds3xfn/ygWyF..."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBC..."

# ── Rate Limiting ──
THROTTLE_TTL=900
THROTTLE_LIMIT=5

# ── MFA ──
MFA_APP_NAME=CaisseFlowPro
